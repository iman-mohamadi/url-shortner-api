// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  isPro       Boolean  @default(false)
  otpCode     String?  // Temporary storage for current valid OTP
  otpExpires  DateTime?
  links       Link[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Link {
  id           String    @id @default(uuid())
  originalUrl  String
  slug         String    @unique
  clicks       Int       @default(0)
  
  // Metadata for the Dashboard
  title        String?
  description  String?
  favicon      String?

  // Pro Features
  customSlug   Boolean   @default(false)
  password     String?   // Hashed password
  expiresAt    DateTime? 
  isActive     Boolean   @default(true)
  
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  analytics    Analytics[]
  createdAt    DateTime  @default(now())
}

model Analytics {
  id        String   @id @default(uuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  
  // Data for the Pro Dashboard
  country   String?
  device    String?  
  browser   String?
  referrer  String?  
  
  timestamp DateTime @default(now())
}